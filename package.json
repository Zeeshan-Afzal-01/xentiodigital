{
  "name": "xentio-digital",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});require('fs').rmSync('node_modules/.cache',{recursive:true,force:true})\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:run": "gcloud run deploy nextjs-server --source . --platform managed --region us-central1 --allow-unauthenticated",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy": "npm run deploy:run && npm run deploy:hosting",
    "deploy:vercel": "vercel --prod"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@uiw/react-md-editor": "^4.0.11",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.0",
    "framer-motion": "^10.18.0",
    "gsap": "^3.14.2",
    "js-cookie": "^3.0.5",
    "lenis": "^1.0.45",
    "lucide-react": "^0.562.0",
    "mapbox-gl": "^3.0.1",
    "next": "^14.0.0",
    "next-auth": "^4.24.13",
    "next-intl": "^3.5.0",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-map-gl": "^7.1.7",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "tailwindcss-rtl": "^0.9.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/gsap": "^3.0.0",
    "@types/mapbox-gl": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tailwindcss-rtl": "^0.9.0",
    "typescript": "^5.2.2"
  }
}
